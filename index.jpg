<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <title>Shenol Perera | Portfolio</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- React and ReactDOM -->
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <!-- Babel for JSX -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <!-- Framer Motion -->
    <script src="https://unpkg.com/framer-motion@10.16.4/dist/framer-motion.js"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@0.344.0/dist/umd/lucide.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap');
        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
            /* Disable text selection for a more app-like feel */
            user-select: none;
            -webkit-user-select: none;
        }
        .backdrop-blur-xl {
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
        }
        .lucide-icon-wrapper i {
            display: inline-block;
            line-height: 0;
        }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect, useRef } = React;
        const { motion, AnimatePresence } = window.Motion;

        const Icon = ({ name, size = 24, className = "" }) => {
            const iconRef = useRef(null);
            useEffect(() => {
                if (iconRef.current) {
                    iconRef.current.innerHTML = '';
                    const iconElement = document.createElement('i');
                    const formattedName = name.replace(/([a-z0-9])([A-Z])/g, '$1-$2').toLowerCase();
                    iconElement.setAttribute('data-lucide', formattedName);
                    iconElement.style.width = `${size}px`;
                    iconElement.style.height = `${size}px`;
                    if (className) iconElement.className = className;
                    iconRef.current.appendChild(iconElement);
                    if (window.lucide) window.lucide.createIcons();
                }
            }, [name, size, className]);
            return <span ref={iconRef} className="lucide-icon-wrapper"></span>;
        };

        const profileImageUrl = "./index.jpg"; 

        const translations = {
            en: {
                home: "Home",
                projects: "Projects",
                contact: "Contact",
                greeting: "Hello, I'm",
                role: "Technology & Security Professional",
                summaryTitle: "Summary",
                summaryText: "Detail-oriented technology professional with a strong focus on secure system architecture, network integrity, and resilient web application development. Experienced in analyzing system vulnerabilities, evaluating risk exposure, and implementing structured defense strategies aligned with modern security standards.",
                projectsBtn: "Explore Projects",
                myProjects: "Recent Projects",
                projectDesc: "Live web applications built with modern frameworks.",
                getInTouch: "Get in Touch",
                nameLabel: "Name",
                emailLabel: "Email",
                messageLabel: "Message",
                send: "Send Message",
                footer: "Developed By Shenol Perera",
                successMsg: "Message sent!",
            },
            ru: {
                home: "Главная",
                projects: "Проекты",
                contact: "Контакты",
                greeting: "Привет, я",
                role: "Специалист по технологиям и безопасности",
                summaryTitle: "Резюме",
                summaryText: "Внимательный к деталям ИТ-специалист с упором на архитектуру защищенных систем, целостность сети и разработку отказоустойчивых веб-приложений.",
                projectsBtn: "Посмотреть проекты",
                myProjects: "Последние проекты",
                projectDesc: "Живые веб-приложения, созданные на современных фреймворках.",
                getInTouch: "Связаться со мной",
                nameLabel: "Имя",
                emailLabel: "Email",
                messageLabel: "Сообщение",
                send: "Отправить",
                footer: "Разработано Шенолом Перерой",
                successMsg: "Сообщение отправлено!",
            }
        };

        const App = () => {
            const [lang, setLang] = useState('en');
            const [activeTab, setActiveTab] = useState('home');
            const [isDarkMode, setIsDarkMode] = useState(true);
            const [time, setTime] = useState(new Date());
            const [imgError, setImgError] = useState(false);
            const t = translations[lang];

            useEffect(() => {
                const timer = setInterval(() => setTime(new Date()), 1000);

                const handleContextMenu = (e) => e.preventDefault();
                document.addEventListener('contextmenu', handleContextMenu);

                const handleKeyDown = (e) => {
                    if (e.keyCode === 123) { e.preventDefault(); return false; }
                    if (e.ctrlKey && e.shiftKey && e.keyCode === 73) { e.preventDefault(); return false; }
                    if (e.ctrlKey && e.shiftKey && e.keyCode === 74) { e.preventDefault(); return false; }
                    if (e.ctrlKey && e.keyCode === 85) { e.preventDefault(); return false; }
                };
                document.addEventListener('keydown', handleKeyDown);

                return () => {
                    clearInterval(timer);
                    document.removeEventListener('contextmenu', handleContextMenu);
                    document.removeEventListener('keydown', handleKeyDown);
                };
            }, []);

            const projectList = [
                { id: 0, title: "Crypto LK", desc: "Real-time crypto tracker.", url: "https://cryptolk.netlify.app/", icon: "TrendingUp", color: "from-yellow-500 to-amber-600" },
                { id: 1, title: "Focus Time", desc: "Productivity timer.", url: "https://loveblefocustimerpro.netlify.app/", icon: "Clock", color: "from-orange-400 to-red-500" },
                { id: 2, title: "QR Generator", desc: "Fast QR tool.", url: "https://loveableqr.netlify.app/", icon: "QrCode", color: "from-blue-400 to-cyan-500" },
                { id: 3, title: "Any Video Downloader by URL", desc: "Download videos from any URL | EXE file", url: "https://drive.google.com/file/d/1YTmDYUZHttnJJ5EVg4J3p1q0pWsXuxVd/view?usp=sharing", icon: "Download", color: "from-red-600 to-rose-700"},
                { id: 4, title: "Metadata Binder", desc: "Image Metadata Binder tool.", url: "/projects/ImageMetadataBinder.html", icon: "ImagePlus", color: "from-purple-600 to-indigo-700"}
            ];

            return (
                <div className={`min-h-screen transition-colors duration-700 overflow-x-hidden ${isDarkMode ? 'bg-[#050505] text-white' : 'bg-[#F2F2F7] text-[#1C1C1E]'}`}>
                    
                    <div className="fixed inset-0 overflow-hidden pointer-events-none opacity-20">
                        <motion.div animate={{ scale: [1, 1.2, 1], rotate: [0, 90, 0] }} transition={{ duration: 20, repeat: Infinity }} className="absolute -top-1/4 -left-1/4 w-full h-full bg-blue-500/20 blur-[120px] rounded-full" />
                    </div>

                    <header className="fixed top-0 w-full z-50 px-6 py-4 flex justify-between items-center backdrop-blur-xl border-b border-white/10">
                        <div className="flex flex-col">
                            <span className="font-bold text-lg">Shenol Perera</span>
                            <span className="text-[10px] font-mono text-blue-500">{time.toLocaleTimeString()}</span>
                        </div>
                        <div className="flex gap-2">
                            <button onClick={() => setIsDarkMode(!isDarkMode)} className="w-10 h-10 flex items-center justify-center bg-white/5 rounded-full border border-white/10">
                                <Icon name={isDarkMode ? "Sun" : "Moon"} size={18} />
                            </button>
                            <button onClick={() => setLang(lang === 'en' ? 'ru' : 'en')} className="px-4 py-1.5 bg-white/5 rounded-full border border-white/10 text-sm font-bold uppercase">
                                {lang}
                            </button>
                        </div>
                    </header>

                    <main className="pt-28 pb-32 px-6 max-w-2xl mx-auto relative z-10">
                        <AnimatePresence mode="wait">
                            {activeTab === 'home' && (
                                <motion.section key="home" initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} exit={{ opacity: 0, y: -20 }} className="space-y-8">
                                    <div className="flex flex-col items-center text-center">
                                        <div className="w-32 h-32 rounded-[2.8rem] overflow-hidden bg-blue-600 shadow-2xl mb-8 flex items-center justify-center border-4 border-white/10 relative">
                                            {!imgError ? (
                                                <img 
                                                    src={profileImageUrl} 
                                                    className="w-full h-full object-cover" 
                                                    alt="Shenol Perera"
                                                    onError={() => setImgError(true)} 
                                                />
                                            ) : (
                                                <div className="bg-blue-600 w-full h-full flex items-center justify-center">
                                                    <Icon name="User" size={56} className="text-white" />
                                                </div>
                                            )}
                                        </div>
                                        <h1 className="text-5xl font-black">{t.greeting} <span className="text-blue-500">Shenol</span></h1>
                                        <p className="text-xl text-gray-400 font-semibold">{t.role}</p>
                                    </div>
                                    <div className="bg-white/5 backdrop-blur-xl p-8 rounded-[2.5rem] border border-white/5">
                                        <p className="text-lg leading-relaxed text-gray-300">{t.summaryText}</p>
                                    </div>
                                    <button onClick={() => setActiveTab('projects')} className="w-full bg-blue-500 text-white font-bold py-5 rounded-[2rem] flex items-center justify-center gap-2 shadow-lg shadow-blue-500/20">
                                        {t.projectsBtn} <Icon name="ChevronRight" size={20} />
                                    </button>
                                </motion.section>
                            )}

                            {activeTab === 'projects' && (
                                <motion.section key="projects" initial={{ opacity: 0, x: 50 }} animate={{ opacity: 1, x: 0 }} className="space-y-6">
                                    <h2 className="text-4xl font-black">{t.myProjects}</h2>
                                    <div className="grid gap-5">
                                        {projectList.map(p => (
                                            <a key={p.id} href={p.url} target="_blank" rel="noopener noreferrer" className="bg-white/5 p-6 rounded-[2rem] border border-white/5 flex items-center justify-between hover:bg-white/10 transition-all group">
                                                <div className="flex items-center gap-5">
                                                    <div className={`p-4 bg-gradient-to-br ${p.color} rounded-2xl text-white shadow-lg`}><Icon name={p.icon} /></div>
                                                    <div>
                                                        <h3 className="font-bold text-xl">{p.title}</h3>
                                                        <p className="text-sm text-gray-400">{p.desc}</p>
                                                    </div>
                                                </div>
                                                <Icon name="ExternalLink" size={20} className="text-blue-500 group-hover:scale-110 transition-transform" />
                                            </a>
                                        ))}
                                    </div>
                                </motion.section>
                            )}

                            {activeTab === 'contact' && (
                                <motion.section key="contact" initial={{ opacity: 0, y: 30 }} animate={{ opacity: 1, y: 0 }} className="space-y-6">
                                    <h2 className="text-4xl font-black">{t.getInTouch}</h2>
                                    <div className="grid grid-cols-2 gap-4">
                                        <a href="mailto:shenolperera5@gmail.com" className="bg-white/5 p-5 rounded-3xl border border-white/5 flex flex-col items-center gap-3 hover:bg-white/10 transition-all"><Icon name="Mail" className="text-red-400" /><span>Email</span></a>
                                        <a href="https://wa.me/94710448110" target="_blank" rel="noopener noreferrer" className="bg-white/5 p-5 rounded-3xl border border-white/5 flex flex-col items-center gap-3 hover:bg-white/10 transition-all"><Icon name="MessageCircle" className="text-green-500" /><span>WhatsApp</span></a>
                                        <a href="https://www.facebook.com/shenol.perera.148/" target="_blank" rel="noopener noreferrer" className="bg-white/5 p-5 rounded-3xl border border-white/5 flex flex-col items-center gap-3 hover:bg-white/10 transition-all"><Icon name="Facebook" className="text-blue-600" /><span>Facebook</span></a>
                                        <a href="https://www.instagram.com/shenol_ravisha/" target="_blank" rel="noopener noreferrer" className="bg-white/5 p-5 rounded-3xl border border-white/5 flex flex-col items-center gap-3 hover:bg-white/10 transition-all"><Icon name="Instagram" className="text-pink-500" /><span>Instagram</span></a>
                                    </div>
                                </motion.section>
                            )}
                        </AnimatePresence>
                    </main>

                    <nav className="fixed bottom-8 left-1/2 -translate-x-1/2 w-[92%] max-w-md z-50">
                        <div className="bg-black/60 backdrop-blur-2xl border border-white/10 rounded-[3rem] p-2 flex justify-around shadow-2xl">
                            {[
                                { id: 'home', icon: "Home", label: t.home },
                                { id: 'projects', icon: "Briefcase", label: t.projects },
                                { id: 'contact', icon: "Mail", label: t.contact },
                            ].map((item) => (
                                <button key={item.id} onClick={() => setActiveTab(item.id)} className={`flex flex-col items-center py-3 px-8 rounded-full transition-all ${activeTab === item.id ? 'text-blue-500 bg-blue-500/10' : 'text-gray-400'}`}>
                                    <Icon name={item.icon} size={22} />
                                    <span className="text-[9px] font-black uppercase mt-1">{item.label}</span>
                                </button>
                            ))}
                        </div>
                    </nav>
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>